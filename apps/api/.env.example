PORT=8787
CLIENT_ORIGIN=http://localhost:4173,http://localhost:5173
JWT_SECRET=replace-with-at-least-32-random-bytes
DATA_DIR=./data
UPLOAD_DIR=./uploads
TRUST_PROXY=1
MEDIA_URL_TTL_SECONDS=900
# 动态照片会调用 FFmpeg 提取并转成兼容浏览器的 H.264；已加入 PATH 时保持 ffmpeg 即可。
FFMPEG_PATH=ffmpeg
# 可选：也可以在网页“约会灵感 → API 设置”中保存，网页保存时会加密写入 SQLite。
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
