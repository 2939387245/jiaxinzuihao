{
  "name": "lumi-couple-space",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c magenta,cyan \"npm run dev -w @lumi/api\" \"npm run dev -w web\"",
    "dev:api": "npm run dev -w @lumi/api",
    "dev:web": "npm run dev -w web",
    "build": "npm run build -w web",
    "start": "npm run start -w @lumi/api"
  },
  "devDependencies": {
    "concurrently": "latest"
  }
}
